{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agentflare hook session-start --agent codex",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agentflare hook prompt-submit --agent codex",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
