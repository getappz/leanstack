{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentflare-web",
  "main": "src/worker.ts",
  "compatibility_date": "2025-04-01",
  "workers_dev": false,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "agentflare.dev", "custom_domain": true },
    { "pattern": "www.agentflare.dev", "custom_domain": true }
  ]
}
