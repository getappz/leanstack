{
  "name": "leanstack",
  "description": "lean-ctx powered token-saving stack. Zero fluff, max context per token.",
  "author": {
    "name": "getappz",
    "url": "https://github.com/getappz"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/session-start.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/prompt-submit.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
